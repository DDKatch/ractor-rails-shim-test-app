# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# If you find yourself ignoring temporary files generated by your editor
# or operating system, consider using a global ignore instead:
#   git config --global core.excludesfile ~/.gitignore_global

# Ignore bundler config.
/.bundle

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, sock files, and databases.
*.pid
*.sock
*.db

# Ignore coverage output.
/coverage/

# Ignore assets precompiled during test/prod.
/public/assets/

# Ignore private keys for the test app (none expected, but be safe).
/config/credentials/*.key

# Ignore local environment overrides.
/.env
/.env.local

# Ignore editor/OS noise.
.DS_Store
*.swp
*~

# Ignore agent/tool cache directories.
.serena/

# Ignore benchmark result artifacts.
/bench/results/
# IPS profiling dumps from benchmark bisects (large, regenerable).
/bench/*.ips
# Benchmark working notes / draft reports (keep bench.rb and the tracked
# harness scripts; these are scratch).
/bench/CONTINUE.md
/bench/FINDINGS.md
/bench/UPSTREAM_REPORT_DRAFT.md
# Ad-hoc bisect / repro scripts kept locally for investigation; not part of
# the tracked benchmark harness.
/bench/load_bisect.rb
/bench/ractor_load.rb
/bench/verify_4.0.6.sh
# Generated StackProf dumps / flamegraphs from the profiling harnesses.
/results/

# Ignore Ruby LSP cache.
/.ruby-lsp/

# Ignore dependency vendoring and node artifacts.
/vendor/
/node_modules/

# Rails master key (decrypts credentials.yml.enc)
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Rails encrypted credentials (decrypts via config/master.key, which is gitignored)
config/credentials.yml.enc
