<div class="devise-card w-full max-w-md rounded-3xl border border-white/10 bg-white/5 p-8 shadow-2xl shadow-black/40 backdrop-blur-xl">
  <div class="mb-6 text-center">
    <%= link_to root_path, class: "inline-flex items-center gap-2" do %>
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-indigo-500 text-lg font-extrabold text-white shadow-lg shadow-indigo-500/30">F</span>
      <span class="text-xl font-extrabold tracking-tight text-white">Full Test App</span>
    <% end %>
    <h1 class="mt-5 text-2xl font-bold text-white">Welcome back</h1>
    <p class="mt-1 text-sm text-indigo-200/70">Sign in to continue</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
    <div>
      <%= f.label :email, class: "mb-1 block text-sm font-medium text-indigo-100/80" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email",
          class: "w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-white placeholder-white/30 outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/40" %>
    </div>

    <div>
      <%= f.label :password, class: "mb-1 block text-sm font-medium text-indigo-100/80" %>
      <%= f.password_field :password, autocomplete: "current-password",
          class: "w-full rounded-xl border border-white/10 bg-white/5 px-4 py-2.5 text-white placeholder-white/30 outline-none transition focus:border-indigo-400 focus:ring-2 focus:ring-indigo-500/40" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <label class="flex items-center gap-2 text-sm text-indigo-100/70">
        <%= f.check_box :remember_me, class: "rounded border-white/20 bg-white/5 text-indigo-500 focus:ring-indigo-500/40" %>
        Remember me
      </label>
    <% end %>

    <%= f.submit "Sign in", class: "w-full rounded-xl bg-gradient-to-r from-indigo-500 to-fuchsia-500 px-4 py-2.5 font-semibold text-white shadow-lg shadow-indigo-500/30 transition hover:opacity-90" %>
  <% end %>

  <div class="mt-6 border-t border-white/10 pt-5 text-center text-sm text-indigo-200/70">
    <%= render "users/shared/links" %>
  </div>
</div>
